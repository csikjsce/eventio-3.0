# Copy to deploy/config.env on the server (gitignored).
# Used by scripts/deploy.sh

REPO_DIR=/vm-storage/projects/eventio-3.0
BACKEND_PORT=3500
APP_PORT=4173
COUNCIL_APP_PORT=4174
NEXT_PUBLIC_SERVER_ADDRESS=https://eventioapi.swdc.somaiya.edu

# GitHub Deployments API — shows status on commits in GitHub UI
# Create a fine-grained PAT or classic token with "Deployments" write access.
GITHUB_TOKEN=
GITHUB_REPO=csikjsce/eventio-3.0
DEPLOY_ENVIRONMENT=production
DEPLOY_ENVIRONMENT_URL=https://eventio.somaiya.edu

# Optional: skip git pull when running locally
# SKIP_GIT_PULL=1
